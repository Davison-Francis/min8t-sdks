{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES5",                          /* Transpile to ES5 for maximum browser compatibility */
    "lib": ["ES5", "DOM"],                    /* Include ES5 and DOM type definitions */

    /* Modules */
    "module": "UMD",                          /* Generate UMD modules for universal compatibility */
    "moduleResolution": "node",               /* Use Node.js module resolution */

    /* Emit */
    "declaration": true,                      /* Generate .d.ts type definition files */
    "declarationMap": true,                   /* Generate source maps for type declarations */
    "sourceMap": true,                        /* Generate source maps for debugging */
    "outDir": "./dist",                       /* Output directory for compiled files */
    "removeComments": false,                  /* Keep comments for better debugging */

    /* Interop Constraints */
    "esModuleInterop": true,                  /* Enable default imports from CommonJS modules */
    "forceConsistentCasingInFileNames": true, /* Enforce consistent file name casing */
    "allowSyntheticDefaultImports": true,     /* Allow default imports from modules with no default export */

    /* Type Checking */
    "strict": true,                           /* Enable all strict type-checking options */
    "noImplicitAny": true,                    /* Raise error on expressions with implied 'any' type */
    "strictNullChecks": true,                 /* Ensure null and undefined are handled */
    "strictFunctionTypes": true,              /* Enable strict checking of function types */
    "strictBindCallApply": true,              /* Enable strict bind/call/apply methods */
    "strictPropertyInitialization": true,     /* Ensure class properties are initialized */
    "noImplicitThis": true,                   /* Raise error on 'this' expressions with implied 'any' type */
    "alwaysStrict": true,                     /* Parse in strict mode and emit "use strict" */

    /* Completeness */
    "skipLibCheck": true,                     /* Skip type checking of declaration files */
    "noUnusedLocals": true,                   /* Report errors on unused local variables */
    "noUnusedParameters": true,               /* Report errors on unused function parameters */
    "noImplicitReturns": true,                /* Report error when not all code paths return a value */
    "noFallthroughCasesInSwitch": true,       /* Report errors for fallthrough cases in switch statements */

    /* Advanced */
    "baseUrl": "./src",                       /* Base directory for resolving non-relative module names */
    "paths": {
      "*": ["*", "types/*"]                   /* Path mapping for module resolution */
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/monitoring",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
